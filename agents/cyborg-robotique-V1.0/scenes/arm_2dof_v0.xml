<mujoco model="cyborg_arm_v0_2dof">
  <option gravity="0 0 -9.81" timestep="0.002"/>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="2 2 0.1" rgba="0.85 0.85 0.85 1"/>

    <body name="base" pos="0 0 0.1">
      <geom name="base_geom" type="cylinder" size="0.06 0.02" rgba="0.4 0.4 0.4 1"/>

      <body name="link1" pos="0 0 0.02">
        <joint name="joint1" type="hinge" axis="0 0 1" range="-180 180" damping="0.1"/>
        <geom name="link1_geom" type="capsule" fromto="0 0 0 0.3 0 0" size="0.03" rgba="0.75 0.3 0.3 1"/>

        <body name="link2" pos="0.3 0 0">
          <joint name="joint2" type="hinge" axis="0 0 1" range="-180 180" damping="0.1"/>
          <geom name="link2_geom" type="capsule" fromto="0 0 0 0.25 0 0" size="0.025" rgba="0.3 0.75 0.3 1"/>

          <body name="end_effector" pos="0.25 0 0">
            <geom name="ee" type="sphere" size="0.04" rgba="0.3 0.3 0.75 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="motor1" joint="joint1" gear="1" ctrlrange="-2 2"/>
    <motor name="motor2" joint="joint2" gear="1" ctrlrange="-2 2"/>
  </actuator>
</mujoco>
